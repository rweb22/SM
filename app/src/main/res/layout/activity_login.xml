<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/back"
    android:orientation="vertical"
    tools:context=".login">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">


        <ImageView
            android:id="@+id/imageView4"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:layout_gravity="center_horizontal"
            android:padding="60dp"
            app:srcCompat="@drawable/login_i" />

        <LinearLayout
            android:id="@+id/enter_block"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:visibility="gone">


            <com.samratmatka.android.latobold
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Enter Your"
                android:textColor="@color/font"
                android:textSize="34sp" />

            <com.samratmatka.android.latobold
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MPIN"
                android:textColor="@color/accent"
                android:textSize="34sp" />


            <EditText
                android:id="@+id/mpin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/edittext2"
                android:hint="Enter your MPIN" />


        </LinearLayout>


        <LinearLayout
            android:id="@+id/create_block"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">


            <com.samratmatka.android.latobold
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/login_your"
                android:textColor="@color/font"
                android:textSize="34sp"
                android:visibility="gone" />

            <com.samratmatka.android.latobold
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Login"
                android:textColor="@color/black"
                android:textSize="34sp" />


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/edittext2"
                android:padding="0dp">

                <ImageView
                    android:id="@+id/imageView5"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:layout_marginLeft="6dp"
                    android:layout_marginRight="8dp"
                    android:tint="#A7A6A6"
                    app:srcCompat="@drawable/smartphone" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:layout_marginRight="5dp"
                    android:paddingLeft="15dp"
                    android:text="+91"
                    android:textColor="@color/font"
                    android:visibility="gone" />

                <EditText
                    android:id="@+id/create_pass"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/blank"
                    android:hint="@string/enter_mobile_number"
                    android:inputType="number"
                    android:maxLength="10"
                    android:paddingTop="15dp"
                    android:paddingBottom="15dp"
                    android:textColorHint="#A7A6A6"
                    android:textSize="13sp" />

            </LinearLayout>


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="12dp"
                android:background="@drawable/edittext2"
                android:orientation="horizontal"
                android:padding="0dp">

                <ImageView
                    android:id="@+id/imageView6"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="center"
                    android:layout_marginLeft="6dp"
                    android:layout_marginRight="10dp"
                    android:tint="#A7A6A6"
                    app:srcCompat="@drawable/padlock" />

                <EditText
                    android:id="@+id/create_pass2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/blank"
                    android:hint="Enter Password"
                    android:inputType="textPassword"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"
                    android:textColorHint="#A7A6A6"
                    android:textSize="13sp" />
            </LinearLayout>


        </LinearLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginRight="5dp">

            <ImageView
                android:layout_width="12dp"
                android:layout_height="9dp"
                android:layout_alignParentRight="true"
                android:elevation="5dp"
                android:paddingRight="-1dp"
                android:src="@drawable/upper_corner"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/submit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentRight="false"
                android:layout_centerHorizontal="false"
                android:layout_marginStart="25dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="15dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/small_round_button_home3"
                android:gravity="center"
                android:padding="15dp">

                <com.samratmatka.android.latobold
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="right"
                    android:layout_marginLeft="40dp"
                    android:layout_marginRight="40dp"
                    android:gravity="center"
                    android:text="@string/_continue"
                    android:textColor="@color/md_white_1000"
                    android:textSize="16sp" />

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="20dp"
                    android:src="@drawable/right_arrow_long"
                    android:tint="@color/white"
                    android:visibility="gone" />

            </LinearLayout>

            <ImageView
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_below="@id/submit"
                android:layout_alignParentRight="true"
                android:elevation="5dp"
                android:paddingRight="-1dp"
                android:src="@drawable/lower_corner"
                android:visibility="gone" />


        </RelativeLayout>


        <com.samratmatka.android.latobold
            android:id="@+id/create"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:text="@string/i_m_new_user"
            android:textColor="@color/lightfont" />

        <com.samratmatka.android.latobold
            android:id="@+id/forgot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="5dp"
            android:gravity="center"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:text="@string/forgot_password"
            android:textColor="@color/lightfont" />


    </LinearLayout>


    <View
        android:layout_width="7dp"
        android:layout_height="match_parent"
        android:layout_alignParentRight="true"
        android:background="@color/accent"
        android:elevation="16dp"
        android:visibility="gone" />


</RelativeLayout>
<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/back"
    tools:context=".GameRate">


    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">


        <androidx.cardview.widget.CardView
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/background">


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:padding="15dp">

                <ImageView
                    android:id="@+id/back"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/back"
                    app:tint="@color/font" />

                <com.tripleseven.android.latobold
                    android:id="@+id/title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="20dp"
                    android:text="Game Rate"
                    android:textColor="@color/font"
                    android:textSize="16sp" />


            </LinearLayout>


        </androidx.cardview.widget.CardView>


        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/toolbar"
            android:layout_marginTop="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="40dp">


                <com.tripleseven.android.latobold
                    android:id="@+id/delhi_market_rate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:gravity="center"
                    android:text="Delhi Market Rates"
                    android:textColor="@color/white"
                    android:textSize="19sp"
                    android:background="@color/font"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp"
                    android:textStyle="bold" />


                <com.tripleseven.android.latonormal
                    android:id="@+id/delhi_jodi_rate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@color/white"
                    android:gravity="center"
                    android:padding="10dp"
                    android:text="Jodi - Loading"
                    android:textColor="@color/font"
                    android:textSize="16sp" />


                <com.tripleseven.android.latonormal
                    android:id="@+id/delhi_harf_rate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@color/white"
                    android:gravity="center"
                    android:padding="10dp"
                    android:text="Harf - Loading"
                    android:textColor="@color/font"
                    android:textSize="16sp" />

                <com.tripleseven.android.latobold
                    android:id="@+id/other_market_rate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:layout_marginTop="40dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp"
                    android:gravity="center"
                    android:text="Other Markets Rates"
                    android:textColor="@color/white"
                    android:background="@color/font"
                    android:textSize="19sp"
                    android:textStyle="bold" />

                <com.tripleseven.android.latonormal
                    android:id="@+id/single_rate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/white"
                    android:gravity="center"
                    android:padding="10dp"
                    android:text="Single - Loading"
                    android:textColor="@color/font"
                    android:textSize="16sp"
                    android:visibility="visible" />


                <com.tripleseven.android.latonormal
                    android:id="@+id/jodi_rate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@color/white"
                    android:gravity="center"
                    android:padding="10dp"
                    android:text="Jodi - Loading"
                    android:textColor="@color/font"
                    android:textSize="16sp" />


                <com.tripleseven.android.latonormal
                    android:id="@+id/sp_rate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@color/white"
                    android:gravity="center"
                    android:padding="10dp"
                    android:text="Sinle Pana - Loading"
                    android:textColor="@color/font"
                    android:textSize="16sp" />

                <com.tripleseven.android.latonormal
                    android:id="@+id/dp_rate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@color/white"
                    android:gravity="center"
                    android:padding="10dp"
                    android:text="Double Pana - Loading"
                    android:textColor="@color/font"
                    android:textSize="16sp"
                    android:visibility="visible" />


                <com.tripleseven.android.latonormal
                    android:id="@+id/tp_rate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@color/white"
                    android:gravity="center"
                    android:padding="10dp"
                    android:text="Triple Pana - Loading"
                    android:textColor="@color/font"
                    android:textSize="16sp"
                    android:visibility="visible" />

                <com.tripleseven.android.latonormal
                    android:id="@+id/halfsangam_rate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@color/white"
                    android:gravity="center"
                    android:padding="10dp"
                    android:text="Half Sangam - Loading"
                    android:textColor="@color/font"
                    android:textSize="16sp"
                    android:visibility="visible" />


                <com.tripleseven.android.latonormal
                    android:id="@+id/fullsangam_rate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@color/white"
                    android:gravity="center"
                    android:padding="10dp"
                    android:text="Full Sangam - Loading"
                    android:textColor="@color/font"
                    android:textSize="16sp"
                    android:visibility="visible" />

                <com.tripleseven.android.latonormal
                    android:id="@+id/single2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="30dp"
                    android:layout_marginBottom="20dp"
                    android:gravity="center"
                    android:text="Starline Win Ratio For All Bids"
                    android:textColor="@color/font"
                    android:textSize="19sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <com.tripleseven.android.latonormal
                    android:id="@+id/st_single"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/white"
                    android:gravity="center"
                    android:padding="10dp"
                    android:text="Single - Loading"
                    android:textColor="@color/font"
                    android:textSize="16sp"
                    android:visibility="gone" />

                <com.tripleseven.android.latonormal
                    android:id="@+id/st_singlepatti"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@color/white"
                    android:gravity="center"
                    android:padding="10dp"
                    android:text="Single Pana - Loading"
                    android:textColor="@color/font"
                    android:textSize="16sp"
                    android:visibility="gone" />

                <com.tripleseven.android.latonormal
                    android:id="@+id/st_doublepatti"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@color/white"
                    android:gravity="center"
                    android:padding="10dp"
                    android:text="Double Pana - Loading"
                    android:textColor="@color/font"
                    android:textSize="16sp"
                    android:visibility="gone" />

                <com.tripleseven.android.latonormal
                    android:id="@+id/st_tripepatti"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@color/white"
                    android:gravity="center"
                    android:padding="10dp"
                    android:text="Triple Pana - Loading"
                    android:textColor="@color/font"
                    android:textSize="16sp"
                    android:visibility="gone" />


            </LinearLayout>

        </ScrollView>


    </RelativeLayout>



</RelativeLayout>
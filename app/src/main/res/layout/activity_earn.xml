<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/white"
    android:orientation="vertical"
    tools:context=".earn">


    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/toolbar"
        android:background="@color/background"
        >

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#d9d5e3">


            <RelativeLayout
                android:id="@+id/back"
                android:layout_width="33dp"
                android:layout_height="33dp"
                android:layout_marginLeft="10dp"
                android:layout_marginTop="10dp"
                android:layout_marginRight="10dp"
                android:layout_marginBottom="10dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/back"
                    app:civ_border_color="#fff"
                    android:layout_centerInParent="true"
                    app:civ_border_width="2dp" />


            </RelativeLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_toRightOf="@id/back">

                <com.tripleseven.android.latobold
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SAMRAT"
                    android:textColor="@color/font"
                    android:textSize="19sp" />

                <com.tripleseven.android.latonormal
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="3dp"
                    android:text="SATTA"
                    android:textColor="@color/font"
                    android:textSize="19sp" />

            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"
                android:layout_marginRight="10dp"
                app:cardCornerRadius="15dp">

                <LinearLayout
                    android:id="@+id/wallet_block"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingLeft="15dp"
                    android:paddingTop="10dp"
                    android:paddingRight="15dp"
                    android:paddingBottom="10dp">


                    <com.tripleseven.android.latonormal
                        android:id="@+id/balance_home"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:layout_marginLeft="5dp"
                        android:layout_marginRight="10dp"
                        android:text="- ₹"
                        android:textColor="@color/font" />

                    <androidx.cardview.widget.CardView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        app:cardBackgroundColor="#f1f3f0"
                        app:cardCornerRadius="7dp">

                        <ImageView
                            android:layout_width="15dp"
                            android:layout_height="15dp"
                            android:layout_margin="5dp"
                            android:src="@drawable/add"
                            android:tint="@color/red" />

                    </androidx.cardview.widget.CardView>


                </LinearLayout>

            </androidx.cardview.widget.CardView>


        </RelativeLayout>


    </RelativeLayout>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        app:cardCornerRadius="5dp"
        android:layout_margin="10dp"
        app:cardElevation="5dp"
        android:layout_height="wrap_content">

        <RelativeLayout
            android:layout_width="match_parent"
            android:background="@drawable/gray_grad2"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="wrap_content"
                android:padding="15dp"
                android:gravity="center"
                android:layout_height="wrap_content"
                >


                <com.tripleseven.android.latobold
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/total_referral"
                    android:textColor="@color/font"
                    />


                <com.tripleseven.android.latobold
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-"
                    android:textSize="16sp"
                    android:layout_marginLeft="10dp"
                    android:textColor="@color/font"
                    android:id="@+id/total_refer"
                    />

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:padding="15dp"
                android:layout_alignParentRight="true"
                android:gravity="center"
                android:layout_height="wrap_content"
                >


                <com.tripleseven.android.latobold
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/total_earnings"
                    android:textColor="@color/font"
                    />

                <com.tripleseven.android.latobold
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹"
                    android:textSize="16sp"
                    android:layout_marginLeft="10dp"
                    android:textColor="@color/font"
                    />

                <com.tripleseven.android.latobold
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-"
                    android:id="@+id/total_earning"
                    android:textSize="16sp"
                    android:textColor="@color/font"
                    />

            </LinearLayout>

        </RelativeLayout>

    </androidx.cardview.widget.CardView>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_marginLeft="15dp"
        android:layout_marginRight="15dp"
        android:layout_height="wrap_content"
        >

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:id="@+id/easy_mode"
            android:gravity="center"
            android:orientation="vertical"
            >

            <com.tripleseven.android.latobold
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="10dp"
                android:text="@string/refer_friends"
                android:id="@+id/easy_text"
                android:textSize="14sp"
                android:textColor="@color/red"
                />

            <View
                android:layout_width="match_parent"
                android:layout_height="1.5dp"
                android:id="@+id/easy_line"
                android:background="@color/red"
                />

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:id="@+id/special_mode"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            >

            <com.tripleseven.android.latobold
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="10dp"
                android:text="@string/my_earnings"
                android:id="@+id/sepcial_text"
                android:textSize="14sp"
                android:textColor="@color/font"
                />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:id="@+id/special_line"
                android:background="@color/white"
                />

        </LinearLayout>


    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:id="@+id/scrollView"
        android:layout_height="match_parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">


            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    >

                  <LinearLayout
                      android:layout_width="match_parent"
                      android:layout_height="wrap_content">

                      <LinearLayout
                          android:layout_width="0dp"
                          android:layout_gravity="center"
                          android:layout_weight="1"
                          android:paddingLeft="10dp"
                          android:padding="10dp"
                          android:orientation="vertical"
                          android:layout_height="wrap_content"
                          >

                          <com.tripleseven.android.latobold
                              android:id="@+id/comm_text"
                              android:layout_width="match_parent"
                              android:layout_height="match_parent"
                              android:text="@string/life_time_comission"
                              android:textColor="@color/font"
                              android:textSize="18sp" />

                          <com.tripleseven.android.latobold
                              android:layout_width="wrap_content"
                              android:layout_height="match_parent"
                              android:textColor="@color/red"
                              android:textSize="18sp" />

                          <TextView
                              android:layout_width="match_parent"
                              android:layout_height="match_parent"
                              android:text="@string/introduce_friends"
                              android:textColor="@color/font"
                              android:textSize="14sp"
                              android:layout_marginTop="5dp"
                              android:textStyle="italic"
                              />



                      </LinearLayout>

                      <ImageView
                          android:layout_width="0dp"
                          android:layout_weight="1"
                          android:layout_height="200dp"
                          android:layout_gravity="right"
                          android:adjustViewBounds="true"
                          android:src="@drawable/refer"
                          />

                  </LinearLayout>


                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        app:cardCornerRadius="5dp"
                        android:layout_margin="10dp"
                        app:cardElevation="5dp"
                        android:layout_height="wrap_content">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:background="@drawable/gray_grad2"
                            android:layout_height="wrap_content">

                            <com.tripleseven.android.latobold
                                android:layout_width="wrap_content"
                                android:layout_centerVertical="true"
                                android:layout_marginLeft="10dp"
                                android:layout_height="wrap_content"
                                android:text="@string/referral_code"
                                android:textSize="16sp"
                                />

                            <com.tripleseven.android.latobold
                                android:id="@+id/code"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_horizontal"
                                android:layout_marginTop="10dp"
                                android:layout_marginBottom="10dp"
                                android:gravity="center"
                                android:paddingLeft="20dp"
                                android:paddingTop="10dp"
                                android:paddingRight="20dp"
                                android:paddingBottom="10dp"
                                android:text="XXXXXXX"
                                android:textColor="@color/font"
                                android:textSize="25sp" />

                            <com.tripleseven.android.latobold
                                android:id="@+id/share"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentRight="true"
                                android:layout_centerVertical="true"
                                android:layout_gravity="center_horizontal"
                                android:layout_marginTop="10dp"
                                android:layout_marginRight="10dp"
                                android:layout_marginBottom="20dp"
                                android:background="@drawable/blue_button_low_rad"
                                android:paddingLeft="20dp"
                                android:paddingTop="10dp"
                                android:paddingRight="20dp"
                                android:paddingBottom="10dp"
                                android:text="@string/copy"
                                android:textColor="#fff"
                                android:textSize="16sp" />



                        </RelativeLayout>

                    </androidx.cardview.widget.CardView>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:gravity="center_vertical"
                        android:layout_height="wrap_content">

                        <ImageView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:id="@+id/facebook"
                            android:layout_height="40dp"
                            android:src="@drawable/facebook_icon"
                            />
                        <ImageView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:id="@+id/telegram"
                            android:layout_height="40dp"
                            android:src="@drawable/telegram_icon"
                            />
                        <ImageView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:id="@+id/shareall"
                            android:layout_height="40dp"
                            android:src="@drawable/share_round"
                            />

                        <ImageView
                            android:layout_width="0dp"
                            android:layout_weight="2"
                            android:id="@+id/whatsapp"
                            android:layout_height="70dp"
                            android:src="@drawable/whatsapp_refer"
                            />


                    </LinearLayout>

                    <com.tripleseven.android.latonormal
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/recently_joined"
                        android:layout_marginLeft="15dp"
                        android:textColor="@color/font"
                        android:layout_marginTop="5dp"
                        android:textSize="18sp"
                        />

                    <androidx.recyclerview.widget.RecyclerView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:id="@+id/user_recycler"
                        />


                </LinearLayout>

            </androidx.core.widget.NestedScrollView>

        </RelativeLayout>

    </androidx.core.widget.NestedScrollView>

    <androidx.recyclerview.widget.RecyclerView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/transactions"
        android:visibility="gone"
        />

</LinearLayout>
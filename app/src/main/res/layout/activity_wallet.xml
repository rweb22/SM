<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:background="@color/background"
    android:layout_height="match_parent"
    tools:context=".wallet">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:padding="15dp">

            <ImageView
                android:id="@+id/back"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/back"
                app:tint="@color/font" />

            <com.samratmatka.android.latobold
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="20dp"
                android:text="@string/my_balance"
                android:textColor="@color/font"
                android:textSize="16sp" />


        </LinearLayout>


        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingBottom="25dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="10dp"
                        android:elevation="2dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="5dp"
                            android:orientation="vertical">


                            <com.samratmatka.android.latonormal
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_margin="10dp"
                                android:gravity="center"
                                android:text="Total Balance"
                                android:textColor="@color/lightfont" />

                            <com.samratmatka.android.latobold
                                android:id="@+id/total_balance"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:text="0 ₹"
                                android:textColor="@color/font"
                                android:textSize="16sp" />

                            <com.samratmatka.android.latobold
                                android:id="@+id/add_money"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:layout_margin="10dp"
                                android:background="@drawable/green_button"
                                android:text="ADD CASH"
                                android:textColor="@color/md_white_1000" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="2dp"
                                android:background="#17000000" />

                            <RelativeLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="5dp"
                                android:padding="10dp">

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical">

                                    <com.samratmatka.android.latonormal
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="DEPOSIT AMOUNT"
                                        android:textColor="@color/lightfont"
                                        android:textSize="12sp" />

                                    <com.samratmatka.android.latobold
                                        android:id="@+id/deposit_balance"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="5dp"
                                        android:text="0 ₹"
                                        android:textColor="@color/font" />

                                </LinearLayout>

                                <ImageView
                                    android:id="@+id/deposit_info"
                                    android:layout_width="35dp"
                                    android:layout_height="35dp"
                                    android:layout_alignParentRight="true"
                                    android:layout_centerVertical="true"
                                    android:padding="8dp"
                                    android:src="@drawable/info_icon"
                                    android:visibility="gone"
                                    app:tint="@color/md_blue_A200" />

                            </RelativeLayout>

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="2dp"
                                android:background="#17000000" />

                            <RelativeLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="5dp"
                                android:padding="10dp">

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical">

                                    <com.samratmatka.android.latonormal
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="WINNINGS"
                                        android:textColor="@color/lightfont"
                                        android:textSize="12sp" />

                                    <com.samratmatka.android.latobold
                                        android:id="@+id/winnig_balance"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="5dp"
                                        android:text="0 ₹"
                                        android:textColor="@color/font" />

                                </LinearLayout>

                                <ImageView
                                    android:id="@+id/winning_info"
                                    android:layout_width="35dp"
                                    android:layout_height="35dp"
                                    android:layout_alignParentRight="true"
                                    android:layout_centerVertical="true"
                                    android:padding="8dp"
                                    android:src="@drawable/info_icon"
                                    android:visibility="gone"
                                    app:tint="@color/md_blue_A200" />

                                <com.samratmatka.android.latobold
                                    android:id="@+id/withdraw_button"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_alignParentRight="true"
                                    android:layout_gravity="center"
                                    android:layout_marginStart="10dp"
                                    android:layout_marginTop="10dp"
                                    android:layout_marginEnd="10dp"
                                    android:layout_marginBottom="10dp"
                                    android:background="@drawable/edittext5"
                                    android:gravity="center"
                                    android:paddingLeft="20dp"
                                    android:paddingTop="10dp"
                                    android:paddingRight="20dp"
                                    android:paddingBottom="10dp"
                                    android:text="WITHDRAW"
                                    android:textColor="@color/colorPrimary"
                                    android:textSize="16sp" />

                            </RelativeLayout>

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="2dp"
                                android:background="#17000000" />

                            <RelativeLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="5dp"
                                android:padding="10dp">

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical">

                                    <com.samratmatka.android.latonormal
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="CASH BONUS"
                                        android:textColor="@color/lightfont"
                                        android:textSize="12sp" />

                                    <com.samratmatka.android.latobold
                                        android:id="@+id/cash_balance"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="5dp"
                                        android:text="0 ₹"
                                        android:textColor="@color/font" />


                                    <com.samratmatka.android.latonormal
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="CASH BONUS"
                                        android:textColor="@color/lightfont"
                                        android:textSize="12sp"
                                        android:visibility="gone" />

                                    <com.samratmatka.android.latobold
                                        android:id="@+id/cash_balanc"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="5dp"
                                        android:text="0 ₹"
                                        android:textColor="@color/font"
                                        android:visibility="gone" />

                                </LinearLayout>

                                <ImageView
                                    android:id="@+id/cash_info"
                                    android:layout_width="35dp"
                                    android:layout_height="35dp"
                                    android:layout_alignParentRight="true"
                                    android:layout_centerVertical="true"
                                    android:padding="8dp"
                                    android:src="@drawable/info_icon"
                                    android:visibility="gone"
                                    app:tint="@color/md_blue_A200" />

                            </RelativeLayout>


                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <ImageView
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:src="@drawable/wallet_ico"
                        android:visibility="gone" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingLeft="10dp"
                        android:visibility="gone">


                        <com.samratmatka.android.latobold
                            android:id="@+id/total_balanc"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="0 ₹"
                            android:textColor="@color/font"
                            android:textSize="17sp" />

                        <com.samratmatka.android.latonormal
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="@string/total_balance"
                            android:textColor="@color/lightfont"
                            android:textSize="13sp" />

                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingLeft="10dp"
                    android:paddingRight="10dp"
                    android:paddingBottom="20dp"
                    android:visibility="gone">

                    <com.samratmatka.android.latobold
                        android:id="@+id/add_mone"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_margin="10dp"
                        android:layout_weight="1"
                        android:background="@drawable/green_button_round"
                        android:gravity="center"
                        android:paddingLeft="20dp"
                        android:paddingTop="10dp"
                        android:paddingRight="20dp"
                        android:paddingBottom="10dp"
                        android:text="@string/add_fund"
                        android:textColor="@color/md_white_1000"
                        android:textSize="16sp" />

                </LinearLayout>

                <com.samratmatka.android.latobold
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="15dp"
                    android:text="@string/my_transaction"
                    android:textColor="@color/font"
                    android:textSize="17sp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

            </LinearLayout>


        </ScrollView>

    </LinearLayout>

    <RelativeLayout
        android:id="@+id/addCash"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#EAEAEA"
        android:clickable="true"
        android:visibility="gone">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content">


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_alignParentBottom="true"
                android:background="#EAEAEA"
                android:clickable="true"
                android:orientation="vertical">


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#FFFFFF"
                    android:padding="15dp">

                    <ImageView
                        android:id="@+id/back_add"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/back"
                        app:tint="@color/font" />

                    <com.samratmatka.android.latobold
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="20dp"
                        android:text="@string/add_cash"
                        android:textColor="@color/font"
                        android:textSize="16sp" />


                </LinearLayout>

                <androidx.appcompat.widget.LinearLayoutCompat
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="15dp">

                    <ImageView
                        android:id="@+id/wallet_color_icon"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:src="@drawable/wallet_some" />

                    <com.samratmatka.android.latonormal
                        android:id="@+id/new_balance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentRight="true"
                        android:layout_centerVertical="true"
                        android:text="₹0"
                        android:textColor="@color/green"
                        android:textSize="23sp" />


                    <com.samratmatka.android.latonormal
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_toRightOf="@id/wallet_color_icon"
                        android:text="@string/total_balance"
                        android:textColor="@color/font"
                        android:textSize="13sp" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="15dp"
                        android:layout_marginTop="15dp"
                        android:layout_marginRight="15dp"
                        android:layout_marginBottom="10dp"
                        android:background="@drawable/edittext3"
                        android:padding="0dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_centerVertical="true"
                            android:layout_marginLeft="10dp"
                            android:src="@drawable/rupee_indian"
                            app:tint="@color/font" />

                        <EditText
                            android:id="@+id/amount2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="25dp"
                            android:background="@drawable/blank"
                            android:hint="@string/enter_amount"
                            android:inputType="number"
                            android:padding="15dp"
                            android:textSize="13sp" />


                    </RelativeLayout>


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center">


                        <com.samratmatka.android.latonormal
                            android:id="@+id/depost_200"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginRight="7dp"
                            android:layout_toLeftOf="@id/depost_1000"
                            android:background="@drawable/shape_square_border"
                            android:paddingLeft="15dp"
                            android:paddingTop="10dp"
                            android:paddingRight="15dp"
                            android:paddingBottom="10dp"
                            android:text="₹200" />

                        <com.samratmatka.android.latonormal
                            android:id="@+id/depost_500"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginRight="7dp"
                            android:layout_toLeftOf="@id/depost_1000"
                            android:background="@drawable/shape_square_border"
                            android:paddingLeft="15dp"
                            android:paddingTop="10dp"
                            android:paddingRight="15dp"
                            android:paddingBottom="10dp"
                            android:text="₹500" />


                        <com.samratmatka.android.latonormal
                            android:id="@+id/depost_1000"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentRight="true"
                            android:layout_centerVertical="true"
                            android:layout_marginRight="7dp"
                            android:background="@drawable/shape_square_border"
                            android:paddingLeft="15dp"
                            android:paddingTop="10dp"
                            android:paddingRight="15dp"
                            android:paddingBottom="10dp"
                            android:text="₹1000" />

                        <com.samratmatka.android.latonormal
                            android:id="@+id/depost_2000"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginRight="7dp"
                            android:layout_toLeftOf="@id/depost_1000"
                            android:background="@drawable/shape_square_border"
                            android:paddingLeft="15dp"
                            android:paddingTop="10dp"
                            android:paddingRight="15dp"
                            android:paddingBottom="10dp"
                            android:text="₹2000" />


                    </LinearLayout>


                </androidx.appcompat.widget.LinearLayoutCompat>

                <com.samratmatka.android.latobold
                    android:id="@+id/add_fund"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp"
                    android:background="@drawable/button_grad"
                    android:gravity="center_horizontal"
                    android:text="@string/add_fund"
                    android:textColor="#fff" />

                <com.samratmatka.android.latobold
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="15dp"
                    android:text="Note"
                    android:textColor="@color/font" />

                <com.samratmatka.android.latonormal
                    android:id="@+id/min_deposit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:text="Minimum Deposit 200/- per transactions\nMaximum deposit - 5 lakhs per day"
                    android:textColor="@color/font" />

                <LinearLayout
                    android:id="@+id/methods"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingLeft="30dp"
                    android:paddingRight="30dp"
                    android:visibility="gone">


                    <LinearLayout
                        android:id="@+id/phonepe_icon"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:layout_weight="1"
                        android:background="@drawable/shape_border"
                        android:orientation="horizontal"
                        android:padding="10dp"
                        android:visibility="visible">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            app:srcCompat="@drawable/phone_pe" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:orientation="vertical">

                            <com.samratmatka.android.latobold
                                android:id="@+id/latobold7"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Phone Pe"
                                android:textColor="@color/font" />

                            <com.samratmatka.android.latobold
                                android:id="@+id/latobold8"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Auto Approve" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/gpay_icon"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:layout_weight="1"
                        android:background="@drawable/shape_border"
                        android:padding="10dp">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_centerInParent="true"
                            android:src="@drawable/googlepay" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:orientation="vertical"
                            android:visibility="visible">

                            <com.samratmatka.android.latobold
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Google Pay"
                                android:textColor="@color/font" />

                            <com.samratmatka.android.latobold
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Auto approve" />

                        </LinearLayout>

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/bhim_icon"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:layout_weight="1"
                        android:background="@drawable/shape_border"
                        android:padding="10dp"
                        android:visibility="visible">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_centerInParent="true"
                            android:src="@drawable/ic_upi" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:orientation="vertical">

                            <com.samratmatka.android.latobold
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Bhim UPI"
                                android:textColor="@color/font" />

                            <com.samratmatka.android.latobold
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/auto_approve" />

                        </LinearLayout>

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/paytm_icon"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:layout_weight="1"
                        android:background="@drawable/shape_border"
                        android:padding="10dp">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_centerInParent="true"
                            android:layout_marginRight="10dp"
                            android:src="@drawable/paytm" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <com.samratmatka.android.latobold
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Paytm UPI"
                                android:textColor="@color/font" />

                            <com.samratmatka.android.latobold
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/auto_approve" />

                        </LinearLayout>


                    </LinearLayout>


                    <LinearLayout
                        android:id="@+id/paytm_gateway"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:layout_weight="1"
                        android:background="@drawable/shape_border"
                        android:padding="10dp"
                        android:visibility="gone">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_centerInParent="true"
                            android:layout_marginRight="10dp"
                            android:src="@drawable/paytm" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <com.samratmatka.android.latobold
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Paytm Gateway"
                                android:textColor="@color/font" />

                            <com.samratmatka.android.latobold
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/auto_apprve_gateway" />

                        </LinearLayout>


                    </LinearLayout>


                    <LinearLayout
                        android:id="@+id/razorpay"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:layout_weight="1"
                        android:background="@drawable/shape_border"
                        android:padding="10dp"
                        android:visibility="gone">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_centerInParent="true"
                            android:layout_marginRight="10dp"
                            android:src="@drawable/razorpay" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <com.samratmatka.android.latobold
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Debit card/Credit card, Net banking"
                                android:textColor="@color/font" />

                            <com.samratmatka.android.latobold
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/auto_apprve_gateway" />

                        </LinearLayout>


                    </LinearLayout>


                    <LinearLayout
                        android:id="@+id/bank"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:layout_weight="1"
                        android:background="@drawable/shape_border"
                        android:padding="10dp">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_centerInParent="true"
                            android:layout_marginRight="10dp"
                            android:src="@drawable/bank_icon" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <com.samratmatka.android.latobold
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Bank Deposit"
                                android:textColor="@color/font" />

                            <com.samratmatka.android.latobold
                                android:id="@+id/bank_details"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content" />

                            <ImageView
                                android:id="@+id/image_preview"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content" />

                        </LinearLayout>


                    </LinearLayout>


                </LinearLayout>


            </LinearLayout>


        </ScrollView>


        <com.samratmatka.android.latobold
            android:id="@+id/deposit_money"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_marginTop="10dp"
            android:layout_marginEnd="10dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/green_button"
            android:gravity="center"
            android:padding="18dp"
            android:text="@string/add_cash"
            android:textColor="@color/md_white_1000"
            android:textSize="16sp"
            android:visibility="gone" />

    </RelativeLayout>




</RelativeLayout>
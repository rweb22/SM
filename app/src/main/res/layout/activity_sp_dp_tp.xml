<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".SpDpTp">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:id="@+id/scrollView"
        android:layout_height="match_parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">


            <androidx.cardview.widget.CardView
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:background="@color/background">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/back"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="15dp"
                        app:cardCornerRadius="10dp"
                        app:cardElevation="5dp">

                        <ImageView
                            android:layout_width="15dp"
                            android:layout_height="15dp"
                            android:layout_margin="10dp"
                            android:src="@drawable/back"
                            app:tint="@color/font" />

                    </androidx.cardview.widget.CardView>


                    <com.tripleseven.android.latobold
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerHorizontal="true"
                        android:layout_centerVertical="true"
                        android:layout_gravity="center_vertical"
                        android:layout_marginLeft="10dp"
                        android:text="SP DP TP"
                        android:textColor="@color/md_black_1000"
                        android:textSize="20sp" />


                </LinearLayout>


            </androidx.cardview.widget.CardView>


            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_below="@id/toolbar">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="15dp"
                            android:background="@color/primary"
                            android:padding="3dp">

                            <com.tripleseven.android.latobold
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:id="@+id/date2"
                                android:layout_weight="4"
                                android:gravity="center"
                                android:padding="15dp"
                                android:text="DEC, 12 2021"
                                android:textColor="@color/md_white_1000"
                                android:textSize="24sp"

                                />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:id="@+id/type_container"
                                android:layout_weight="6"
                                android:background="@color/md_white_1000"
                                android:orientation="vertical"
                                android:padding="10dp">

                                <com.tripleseven.android.latobold
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:id="@+id/open_game"
                                    android:background="@color/primary"
                                    android:textColor="@color/md_white_1000"
                                    android:gravity="center"
                                    android:padding="10dp"
                                    android:text="OPEN"
                                    />

                                <com.tripleseven.android.latobold
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="10dp"
                                    android:id="@+id/close_game"
                                    android:background="@color/gray"
                                    android:gravity="center"
                                    android:textColor="@color/font"
                                    android:padding="10dp"
                                    android:text="CLOSE"

                                    />

                            </LinearLayout>


                        </LinearLayout>


                        <Spinner
                            android:id="@+id/type"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="20dp"
                            android:layout_marginTop="10dp"
                            android:layout_marginEnd="20dp"
                            android:background="@drawable/edittext"
                            android:padding="5dp"
                            android:visibility="gone" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">

                                <com.tripleseven.android.latobold
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="20dp"
                                    android:layout_marginTop="20dp"
                                    android:layout_marginBottom="5dp"
                                    android:text="Bid Digits"
                                    android:textColor="@color/md_black_1000"
                                    android:textSize="15sp" />

                                <EditText
                                    android:id="@+id/number"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="20dp"
                                    android:layout_marginEnd="20dp"
                                    android:background="@drawable/edittext"
                                    android:completionThreshold="0"
                                    android:maxLength="1"
                                    android:hint="Enter Digit"
                                    android:inputType="number"
                                    android:textSize="13sp" />



                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginLeft="18dp"
                                    android:id="@+id/spdptp_panel"
                                    android:layout_marginRight="18dp"
                                    android:layout_marginTop="10dp"
                                    android:background="@color/md_white_1000"
                                    android:padding="10dp">

                                    <com.tripleseven.android.latobold
                                        android:layout_width="0dp"
                                        android:layout_weight="1"
                                        android:layout_height="wrap_content"
                                        android:background="@color/gray"
                                        android:textColor="@color/font"
                                        android:gravity="center"
                                        android:padding="10dp"
                                        android:text="Single Pana"
                                        android:id="@+id/single_panna"
                                        android:layout_marginRight="5dp"
                                        />

                                    <com.tripleseven.android.latobold
                                        android:layout_width="0dp"
                                        android:layout_weight="1"
                                        android:layout_height="wrap_content"
                                        android:layout_marginLeft="5dp"
                                        android:id="@+id/double_panna"
                                        android:background="@color/gray"
                                        android:gravity="center"
                                        android:textColor="@color/font"
                                        android:padding="10dp"
                                        android:text="Double Pana"

                                        />

                                    <com.tripleseven.android.latobold
                                        android:layout_width="0dp"
                                        android:layout_weight="1"
                                        android:layout_height="wrap_content"
                                        android:layout_marginLeft="5dp"
                                        android:id="@+id/triple_panna"
                                        android:background="@color/gray"
                                        android:gravity="center"
                                        android:textColor="@color/font"
                                        android:padding="10dp"
                                        android:text="Triple Pana"

                                        />


                                </LinearLayout>

                                <androidx.recyclerview.widget.RecyclerView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:id="@+id/sample_recycler"
                                    android:layout_marginLeft="18dp"
                                    android:layout_marginTop="10dp"
                                    android:background="@color/md_white_1000"
                                    android:layout_marginRight="18dp"
                                    />


                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">

                                <com.tripleseven.android.latobold
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="20dp"
                                    android:layout_marginTop="20dp"
                                    android:layout_marginBottom="5dp"
                                    android:text="Bid Points"
                                    android:textColor="@color/md_black_1000"
                                    android:textSize="15sp" />

                                <EditText
                                    android:id="@+id/amount2"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="20dp"
                                    android:layout_marginEnd="20dp"
                                    android:background="@drawable/edittext"
                                    android:hint="Enter Amount"
                                    android:inputType="number"
                                    android:textSize="13sp" />


                            </LinearLayout>


                        </LinearLayout>


                        <com.tripleseven.android.latobold
                            android:id="@+id/add"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="20dp"
                            android:layout_marginTop="16sp"
                            android:layout_marginRight="20dp"
                            android:background="@drawable/button"
                            android:gravity="center_horizontal"
                            android:text="ADD BID"
                            android:textColor="#fff" />


                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:layout_marginTop="20dp"
                        android:visibility="gone"
                        android:background="#23000000" />


                    <!--          <androidx.cardview.widget.CardView-->
                    <!--              android:layout_width="match_parent"-->
                    <!--              android:layout_height="wrap_content"-->
                    <!--              android:layout_margin="15dp"-->
